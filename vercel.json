{
  "version": 2,
  "functions": {
    "public/index.php": {
      "runtime": "@vercel/php@0.8.3"
    }
  },
  "rewrites": [{
    "source": "/(.*)",
    "destination": "/public/index.php"
  }],
  "headers": [{
    "source": "/build/(.*)",
    "headers": [{
      "key": "Cache-Control",
      "value": "public, max-age=31536000, immutable"
    }]
  }]
}
